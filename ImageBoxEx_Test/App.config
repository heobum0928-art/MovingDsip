<?xml version="1.0" encoding="utf-8" ?>
<configuration>

  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net" />
  </configSections>

  <log4net>
    <root>
      <priority value="INFO" />
      <appeder-ref ref="RollingLogFileAppender" />
    </root>

    <logger name="CommunicationSettings">
      <level value="DEBUG" />
      <appender-ref ref="DelegateAppender" />
      <appender-ref ref="File" />
    </logger>

    <logger name="AppLogger">
      <level value="DEBUG" />
      <appender-ref ref="DelegateAppender" />
      <appender-ref ref="File" />
    </logger>

    <appender name="RollingLogFileAppender" type="log4net.Appender.RollingFileAppender, log4net">
      <param name="File" value="d:\log\ImageBoxEx_Test.log" />
      <param name="AppendToFile" value="true" />
      <param name="MaxSizeRollBackups" value="100" />
      <param name="MaximumFileSize" value="5MB" />
      <param name="RollingStyle" value="Size" />
      <param name="StaticLogFileName" value="true" />
      <layout type="log4net.Layout.PatternLayout, log4net">
        <param name="ConversionPattern" value="%d [%t] %5p (%C:%M:%L) - %m%n" />
      </layout>
    </appender>

    <appender name="DelegateAppender" type="Project.BaseLib.Logger.DelegateAppender">
      <layout type="log4net.Layout.PatternLayout">
        <param name="ConversionPattern" value="%date [%-5.5thread] [%-5level] [%-20.20logger] - %message%newline" />
      </layout>
    </appender>

    <appender name="File" type="Project.BaseLib.Logger.MessageLogRollingAppender">
      <file value="..\logs\ImageBoxEx_Test\ImageBoxEx_Test.log" />
      <PreserveLogFileNameExtension value="true" />
      <appendToFile value="false" />
      <rollingStyle value="Size" />
      <maxSizeRollBackups value="100" />
      <maxSizeCompressedBackups value="1000" />
      <keepCompressedDays value="30" />
      <maximumFileSize value="10MB" />
      <staticLogFileName value="true" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%-5.5thread] [%-5level] [%-25.25property{memberName}] [%5.5property{lineNumber}] - %message%newline" />
      </layout>
    </appender>

    <appender name="LongFile" type="Project.BaseLib.Logger.MessageLogRollingAppender">
      <file value="..\logs\ImageBoxEx_Test\ImageBoxEx_Test.log" />
      <PreserveLogFileNameExtension value="true" />
      <appendToFile value="false" />
      <rollingStyle value="Size" />
      <maxSizeRollBackups value="100" />
      <maxSizeCompressedBackups value="1000" />
      <keepCompressedDays value="30" />
      <maximumFileSize value="10MB" />
      <staticLogFileName value="true" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%-5.5thread] [%-5level] [%-25.25property{fileName}] [%-25.25property{memberName}] [%5.5property{lineNumber}] [%-15.15logger] - %message%newline" />
      </layout>
    </appender>
  </log4net>
  
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
</configuration>