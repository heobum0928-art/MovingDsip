<Window x:Class="ReringProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReringProject"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        xmlns:setting="clr-namespace:ReringProject.Setting"
        xmlns:ui="clr-namespace:ReringProject.UI"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Height="649" Width="1280" Loaded="Window_Loaded" Closing="Window_Closing">
 
    <Grid x:Name="MainGrid" ShowGridLines="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="26"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="78*"></RowDefinition>
            <RowDefinition Height="26"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="75*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="25*"/>
        </Grid.ColumnDefinitions>
        
        <!-- TitleBar -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" ShowGridLines="False" Background="#c7e6fd" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition Width="42"></ColumnDefinition>
                <ColumnDefinition Width="32"></ColumnDefinition>
                <ColumnDefinition Width="32"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>


            <Label x:Name="Title" Grid.Column="0" FontSize="12" FontWeight="Bold" Content="{Binding [Window_Title], Source={StaticResource DR}}"
                   MouseDown="Title_MouseDown" MouseMove="Title_MouseMove"></Label>
            <TextBlock x:Name="ComboLanguage" FontSize="12" Margin="0,2,0,2" Grid.Column="1" Visibility="Visible" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"
                  Text="{Binding ElementName=Title, Path=Language}"/>
            <Button x:Name="MinimizeButton" FontSize="12" Grid.Column="2" BorderThickness="1" Margin="2" Click="MinimizeButton_Click" Background="Transparent" >
                <Image Source="/Resource/minimize.png" ></Image>
            </Button>
            <Button x:Name="CloseButton" FontSize="12" Grid.Column="3" BorderThickness="1" Margin="2" Click="CloseButton_Click" Background="Transparent" >
                <Image Source="/Resource/exit.png" ></Image>
            </Button>
        </Grid>

        <!-- MenuBar -->
        <DockPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <ui:MenuBar x:Name="menuBar"></ui:MenuBar>
        </DockPanel>
        
        <!-- Contents -->
        <Grid Grid.Row="2" Grid.Column="0" Background="Beige">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="8*"></RowDefinition>
                <RowDefinition Height="5"></RowDefinition>
                <RowDefinition Height="1*"></RowDefinition>
            </Grid.RowDefinitions>
            
            <ui:MainView x:Name="mainView" Grid.Column="0" Grid.Row="0"/>
            <GridSplitter Grid.Column="0" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" ShowsPreview="True" Height="5" BorderBrush="Gray" BorderThickness="1"></GridSplitter>
            <ui:LogView x:Name="logView" Grid.Column="0" Grid.Row="2"></ui:LogView>
        </Grid>
        
        <!-- Splitter -->
        <GridSplitter Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" ShowsPreview="True" Width="5" BorderBrush="Gray" BorderThickness="1"></GridSplitter>
        
        <!-- Control -->
        <DockPanel Grid.Row="2" Grid.Column="2" Background="Lavender">
            <ui:InspectionListView x:Name="inspectionList"></ui:InspectionListView>
        </DockPanel>

        <!-- Status -->
        <DockPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
            <ui:StatusBar x:Name="statusBar"></ui:StatusBar>
        </DockPanel>
    </Grid>
</Window>
        
    
    
