<UserControl x:Class="ReringProject.UI.StatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReringProject.UI"
             mc:Ignorable="d" 
             d:DesignHeight="25" d:DesignWidth="1280" Loaded="StatusBar_Loaded">
    <Border BorderThickness="1" BorderBrush="Gray">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"></ColumnDefinition>
            <ColumnDefinition Width="1*"></ColumnDefinition>
            <ColumnDefinition Width="1*"></ColumnDefinition>
            <ColumnDefinition Width="1*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        
        <!-- Progress -->
        <Label x:Name="label_Status" Grid.Column="0" Grid.Row="0" FontSize="12" Content="{Binding Path=Message, Mode=OneWay}"></Label>
        
        <!-- CPU Usage -->
        <ProgressBar x:Name="progressBar_cpu" Grid.Column="1" Grid.Row="0" Maximum="100" Value="{Binding Path=CpuUsage, Mode=OneWay}" Margin="0,2,2,2">
        </ProgressBar>
            
        <TextBlock Grid.Column="1" Text="{Binding ElementName=progressBar_cpu, Path=Value, StringFormat={}Cpu Usage:{0:0}%}" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- RAM Usage -->
        <ProgressBar x:Name="progressBar_ram" Grid.Column="2" Grid.Row="0" Maximum="{Binding Path=RamTotal, Mode=OneWay}" Value="{Binding Path=RamUsage, Mode=OneWay}" Margin="0,2,2,2">
        </ProgressBar>
            <TextBlock Grid.Column="2" Text="{Binding ElementName=progressBar_ram, Path=Value, StringFormat={}Ram Usage:{0:0}MB}" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" />


            <!-- Local Drive -->
        <ProgressBar x:Name="progressBar_hard" Grid.Column="3" Grid.Row="0" Maximum="100" Value="{Binding Path=HddUsage, Mode=OneWay}" Margin="2,2,2,2">
        </ProgressBar>

        <TextBlock Grid.Column="3" Text="{Binding ElementName=progressBar_hard, Path=Value, StringFormat={}HDD Usage:{0:0}%}"  
                   HorizontalAlignment="Center" VerticalAlignment="Center" />

    </Grid>
    </Border>
</UserControl>
