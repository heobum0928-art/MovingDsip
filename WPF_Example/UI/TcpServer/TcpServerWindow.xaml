<Window x:Class="ReringProject.UI.TcpServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReringProject.UI"
        mc:Ignorable="d"
        Title="TcpServerWindow" Height="600" Width="800" WindowStyle="SingleBorderWindow" WindowStartupLocation="CenterOwner" Loaded="Window_Loaded" Closed="Window_Closed">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="5"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Column="0" Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"></RowDefinition>
                <RowDefinition Height="9*"></RowDefinition>
            </Grid.RowDefinitions>

            <ComboBox Grid.Column="0" Grid.Row="0" x:Name="comboBox_connectedClient" FontSize="24" ItemsSource="{Binding ConnectedList}" SelectedIndex="{Binding SelectedIndex}" SelectionChanged="ComboBox_connectedClient_SelectionChanged"></ComboBox>
            <ListBox Grid.Column="0" Grid.Row="1" x:Name="listBox_message" ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="0,4,0,0" ItemsSource="{Binding MessageList}"></ListBox>
        </Grid>

        <GridSplitter Grid.Column="1" Grid.Row="0" BorderBrush="Gray" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Stretch"></GridSplitter>

        <Grid Grid.Column="2" Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"></RowDefinition>
                <RowDefinition Height="9*"></RowDefinition>
                <RowDefinition Height="50"></RowDefinition>
            </Grid.RowDefinitions>

            <DockPanel Grid.Column="0" Grid.Row="0">
                <TextBox x:Name="textBox_send" Width="300" FontSize="24" Text="{Binding SendText}"></TextBox>
                <Button x:Name="button_send" Content="SEND" Click="Button_send_Click" Margin="4,0,0,0" FontSize="16"></Button>
            </DockPanel>


            <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Vertical">
                <!-- Recipe -->
                <GroupBox Header="RECIPE">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="button_send_recipe_set" Height="40" Width="120" Content="Recipe Set" Margin="5" Click="Button_send_recipe_set_Click"></Button>
                        <Button x:Name="button_send_recipe_list" Height="40" Width="120" Content="Recipe List" Margin="5" Click="Button_send_recipe_list_Click"></Button>
                    </StackPanel>
                </GroupBox>

                <!-- Light -->
                <GroupBox Header="LIGHT">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="button_send_light_set" Height="40" Width="120" Content="Light Set" Margin="5" Click="Button_send_light_set_Click"></Button>
                    </StackPanel>
                </GroupBox>

                <!-- status -->
                <GroupBox Header="STATUS">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="button_send_status" Height="40" Width="120" Content="Site Status" Margin="5" Click="Button_send_status_Click"></Button>
                    </StackPanel>
                </GroupBox>

                <!-- test -->
                <GroupBox Header="TEST">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="button_grab_status" Height="40" Width="120" Content="Grab Status" Margin="5" Click="Button_grab_status_Click"></Button>
                        <Button x:Name="button_test_result" Height="40" Width="120" Content="Test Result" Margin="5" Click="Button_test_result_Click"></Button>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <Button Grid.Column="0" Grid.Row="2" x:Name="button_close" Content="Close" FontSize="20" Click="Button_close_Click"></Button>
            
        </Grid>
        
    </Grid>
</Window>
