<Window x:Class="ReringProject.UI.TextInputBoxWinidow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReringProject.UI"
        mc:Ignorable="d"
        Title="TextInputBox" Height="180" Width="400" WindowStyle="None" WindowStartupLocation="CenterOwner" IsVisibleChanged="Window_IsVisibleChanged">
    <Border BorderThickness="5" BorderBrush="SkyBlue">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"></RowDefinition>
                <RowDefinition Height="2*"></RowDefinition>
                <RowDefinition Height="2*"></RowDefinition>
            </Grid.RowDefinitions>
            <Label x:Name="label_title" Grid.Column="0" Grid.Row="0" FontSize="18" VerticalContentAlignment="Bottom">Please Input Text :</Label>
            <TextBox x:Name="textBox_text" Grid.Column="0" Grid.Row="1" Margin="5" FontSize="22" KeyUp="TextBox_text_KeyUp"></TextBox>
            <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                <Button x:Name="button_cancel" MinWidth="100" FontSize="22" Margin="0,0,4,0" Click="Button_cancel_Click">Cancel</Button>
                <Button x:Name="button_ok" MinWidth="100" FontSize="22" Click="Button_ok_Click">Ok</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
