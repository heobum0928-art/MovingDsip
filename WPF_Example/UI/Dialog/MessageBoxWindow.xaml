<Window x:Class="ReringProject.UI.MessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReringProject.UI"
        mc:Ignorable="d"
        Title="Message Box" Height="450" Width="800" 
        WindowStyle="None" WindowStartupLocation="CenterOwner" Closed="Window_Closed">
    <Border x:Name="border_outline" BorderThickness="10" BorderBrush="Red">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="6*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
            <Image x:Name="image_state" Source="{Binding ImageSource}"></Image>
                <Label x:Name="label_state" FontSize="42" Margin="10,0,0,0" Content="{Binding Title}"></Label>
        </StackPanel>
        
        <TextBox x:Name="textBox_message" Grid.Column="0" Grid.Row="1" FontSize="34" Margin="10,10,10,0" Text="{Binding Message}" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"></TextBox>

        <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,10,0,10">
                <Button x:Name="button_yes" Width="160" FontSize="36" Margin="0,0,10,0" Click="Button_yes_Click" Visibility="Visible">Yes</Button>
                <Button x:Name="button_no" Width="160" FontSize="36" Margin="0,0,10,0" Click="Button_no_Click" Visibility="Visible">No</Button>
                <Button x:Name="button_cancel" Width="160" FontSize="36" Margin="0,0,10,0" Click="Button_cancel_Click" Visibility="Visible">Cancel</Button>
            <Button x:Name="button_ok" Width="160" FontSize="36" Click="Button_ok_Click">OK</Button>
        </StackPanel>
    </Grid>
    </Border>
</Window>
