<Window x:Class="ReringProject.UI.LogViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReringProject.UI"
        xmlns:mdi="clr-namespace:WPF.MDI;assembly=WPF.MDI"
        mc:Ignorable="d"
        Title="LogViewWindow" Height="450" Width="800" WindowStartupLocation="CenterOwner">
    <mdi:MdiContainer x:Name="Container">
        <mdi:MdiContainer.Menu>
            <Menu DockPanel.Dock="Top">
                <MenuItem x:Name="menuItem_add" Header="Add">
                    <!-- list of logging items...-->
                </MenuItem>
                <MenuItem x:Name="menuItem_windows" Header="Windows" x:FieldModifier="private"></MenuItem>
            </Menu>
        </mdi:MdiContainer.Menu>

    </mdi:MdiContainer>
</Window>
