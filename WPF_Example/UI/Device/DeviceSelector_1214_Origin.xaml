<Window x:Class="ReringProject.UI.DeviceSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:ReringProject.UI"
        xmlns:propTools="clr-namespace:PropertyTools.Wpf;assembly=PropertyTools.Wpf"
        xmlns:lightGroup="clr-namespace:ReringProject.UI"
        mc:Ignorable="d"
        Title="DeviceSelector" Height="860" Width="1024"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" WindowState="Maximized"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <!-- property grid customize-->
        <!-- Category Header -->
        <DataTemplate x:Key="HeaderTemplate1">
            <StackPanel Orientation="Horizontal">
                <propTools:Bitmap Source="/Resource/home.png"/>
                <TextBlock Text="{Binding}" FontSize="14" FontWeight="Bold" Margin="4,0,0,0"/>
            </StackPanel>
        </DataTemplate>
        <!-- Unused : TabPageHeader -->
        <DataTemplate x:Key="PageHeaderTemplate1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding }" FontSize="18" FontWeight="Bold" Margin="0 0 8 0"/>
                <propTools:Bitmap Source="/Resource/home.png" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
        <!-- Error Style-->
        <Style x:Key="TabHeaderErrorsStyle">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasWarnings}" Value="True">
                    <Setter Property="TextBlock.Foreground" Value="Orange"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasErrors}" Value="True">
                    <Setter Property="TextBlock.Foreground" Value="Red"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Tab Header -->
        <DataTemplate x:Key="HeaderTemplate2" DataType="propTools:Tab">
            <StackPanel Orientation="Horizontal">
                <propTools:Bitmap Source="/Resource/chart.png" Margin="0 0 4 0"/>
                <TextBlock Text="{Binding Header}" Margin="4 0 0 0" Style="{StaticResource TabHeaderErrorsStyle}"/>
            </StackPanel>
        </DataTemplate>
        <!-- CategoryControl -->
        <ControlTemplate x:Key="CategoryControlTemplate1"  TargetType="{x:Type HeaderedContentControl}">
            <Grid Margin="0 8 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                <Separator Grid.Column="1" Margin="4 3 0 0"/>
                <ContentPresenter Grid.Row="1" Grid.ColumnSpan="2"/>
            </Grid>
        </ControlTemplate>
        
        <ContextMenu x:Key="menu_etc" x:Name="contextMenu_etc" FontSize="18">
            <ContextMenu.Items>
                <MenuItem x:Name="menu_saveImage" Header="Save Image" MinHeight="34" Click="MenuItem_SaveImage_Click"></MenuItem>
                <MenuItem x:Name="menu_openDir" Header="Open Image Dir" MinHeight="34" Click="Menu_openDir_Click"></MenuItem>

                <Separator></Separator>
                <MenuItem x:Name="menu_loadImage" Header="Load Image in directory" MinHeight="36" Click="MenuItem_LoadImage_Click"></MenuItem>
                <MenuItem x:Name="menu_nextImage" Header="Next Image" MinHeight="36" Click="Menu_nextImage_Click"></MenuItem>
                <MenuItem x:Name="menu_prevImage" Header="Prev Image" MinHeight="36" Click="Menu_prevImage_Click"></MenuItem>
                <Separator></Separator>
                <MenuItem x:Name="menu_streaming" Header="Streaming" MinHeight="34" Click="Menu_streaming_Click" IsCheckable="True"></MenuItem>
                
            </ContextMenu.Items>
        </ContextMenu>

    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*"></ColumnDefinition>
            <ColumnDefinition Width="5"></ColumnDefinition>
            <ColumnDefinition Width="3*"></ColumnDefinition>    
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"></RowDefinition>
            <RowDefinition Height="9*"></RowDefinition>
        </Grid.RowDefinitions>

        <!-- device Selector -->
        <Grid Grid.Column="0" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <ComboBox x:Name="combo_device" Grid.Column="0" Grid.Row="0" Margin="4,4,4,4" FontSize="20" ItemsSource="{Binding DeviceList}" SelectionChanged="Combo_device_SelectionChanged" SelectedIndex="{Binding SelectedNum}" SelectedItem="{Binding SelectedItem}" MaxDropDownHeight="{Binding DropdownHeight}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding SourceImage}" MaxHeight="48" MaxWidth="48" Margin="10,0,10,0"></Image>
                            <TextBlock Text="{Binding Name}"></TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <propTools:SpinControl x:Name="spin_zoom" Grid.Column="1" Grid.Row="0" Margin="0,4,0,4" Value="{Binding DrawScale}" Minimum="{Binding DrawScaleMin}" Maximum="{Binding DrawScaleMax}" SmallChange="0.1" LargeChange="0.5">
                <TextBox Text="{Binding DrawScale, StringFormat={}{0:0.0}}" FontSize="24" BorderThickness="0" HorizontalContentAlignment="Right"></TextBox>
            </propTools:SpinControl>
            <Button x:Name="btn_etc" Grid.Column="2" Grid.Row="0" Margin="4,4,4,4" Content="..." FontSize="32" Click="Btn_etc_Click" ContextMenu="{Binding Path=menu_etc}"></Button>
        </Grid>
        <GridSplitter Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" BorderBrush="Gray" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Stretch"></GridSplitter>
        
        <!-- property grid -->
        <Grid Grid.Column="2" Grid.Row="0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"></RowDefinition>
                <RowDefinition Height="9*"></RowDefinition>
                <RowDefinition Height="64"></RowDefinition>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Grid.Column="0">
                <DockPanel DockPanel.Dock="Top">
                    <TextBlock x:Name="textBlock_selectedMode" FontSize="14" Text="{Binding SelectedItem.Mode, ElementName=combo_device}" Margin="4,0,0,4"></TextBlock>
                    <TextBlock x:Name="textBlock_fps" Text="FPS : 15" Margin="0,0,4,0" FontSize="14" HorizontalAlignment="Right"></TextBlock>
                </DockPanel>

                <DockPanel DockPanel.Dock="Bottom" >
                    <TextBlock x:Name="textBlock_state" Text="" Margin="4,0,0,0" FontSize="14"></TextBlock>
                </DockPanel>
            </DockPanel>
            <TabControl Grid.Column="0" Grid.Row="1">
                <TabItem Header="Camera Property">
                    <propTools:PropertyGrid x:Name="propertyGrid_device" Margin="0" BorderThickness="0" BorderBrush="Gray" 
                                                CategoryControlTemplate="{StaticResource CategoryControlTemplate1}"
                                                CategoryHeaderTemplate="{StaticResource HeaderTemplate1}"
                                                TabHeaderTemplate="{StaticResource HeaderTemplate2}"
                                                DescriptionIcon="/Resource/lightbulb.png"
                                                SelectedObject="{Binding SelectedItem.Property, ElementName=combo_device}">
                    </propTools:PropertyGrid>
                </TabItem>
                <TabItem Header="Light">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" >
                        <StackPanel x:Name="stackPanel_light" >
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Display">
                    <propTools:PropertyGrid x:Name="propertyGrid_displayConfig" Margin="0" BorderThickness="0" BorderBrush="Gray" 
                                                CategoryControlTemplate="{StaticResource CategoryControlTemplate1}"
                                                CategoryHeaderTemplate="{StaticResource HeaderTemplate1}"
                                                TabHeaderTemplate="{StaticResource HeaderTemplate2}"
                                                DescriptionIcon="/Resource/lightbulb.png"
                                                SelectedObject="{Binding SelectedItem.Config, ElementName=combo_device}">
                    </propTools:PropertyGrid>
                </TabItem>
            </TabControl>
            <Grid Grid.Column="0" Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Button x:Name="btn_cancel" Grid.Column="0" Content="Cancel" FontSize="24" Margin="4,4,0,4" Click="Btn_cancel_Click"></Button>
                <Button x:Name="btn_ok" Grid.Column="1" Content="OK" FontSize="24" Margin="4,4,4,4" Click="Btn_ok_Click"></Button>
            </Grid>
        </Grid>
        
        <!-- image display -->
        <ScrollViewer x:Name="scrollViewer" Grid.Column="0" Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#FF303030">
            <local:CanvasViewer x:Name="canvas_preview" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Canvas.Background>
                    <ImageBrush Stretch="None" AlignmentX="Left" AlignmentY="Top"></ImageBrush>
                </Canvas.Background>
                <Image Canvas.Left="0" Canvas.Top="0" x:Name="image_foreground" Stretch="None" VerticalAlignment="Top" HorizontalAlignment="Left" Opacity="1" OpacityMask="Black" Width="{Binding Width, ElementName=canvas_preview}" Height="{Binding Height, ElementName=canvas_preview}"></Image>
                
                <Canvas.RenderTransform>
                    <ScaleTransform x:Name="scaleTransform" ScaleX="{Binding DrawScale}" ScaleY="{Binding DrawScale}" CenterX="0" CenterY="0">
                    </ScaleTransform>
                </Canvas.RenderTransform>
            </local:CanvasViewer>
        </ScrollViewer>

    </Grid>
</Window>
