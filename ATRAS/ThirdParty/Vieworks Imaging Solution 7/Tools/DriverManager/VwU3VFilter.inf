[VWUSBCam.Dev.NT]
CopyFiles=VWUSBCam.Files.Ext
AddReg=VWUSBCam.AddReg

[VWUSBCam.Dev.NT.HW]
AddReg=VWUSBCam.AddReg.Guid

[VWUSBCam.Dev.NT.Services]
Addservice = VWUSBCam, %SPSVCINST_ASSOCSERVICE%, VWUSBCam.AddService

[VWUSBCam.Dev.NTamd64]
CopyFiles=VWUSBCam.Files.Ext
AddReg=VWUSBCam.AddReg

[VWUSBCam.Dev.NTamd64.HW]
AddReg=VWUSBCam.AddReg.Guid

[VWUSBCam.Dev.NTamd64.Services]
Addservice = VWUSBCam, %SPSVCINST_ASSOCSERVICE%, VWUSBCam.AddService

[VWUSBCam.AddService]
DisplayName=%VWUSBCam.SvcDesc%
ServiceType=1                  ; SERVICE_KERNEL_DRIVER
StartType=3                  ; SERVICE_DEMAND_START
ErrorControl=1                  ; SERVICE_ERROR_NORMAL
ServiceBinary=%10%\System32\Drivers\VwU3VFilter.sys
AddReg=VWUSBCam.AddReg
LoadOrderGroup=Base

[VWUSBCam.AddReg]
HKR,"Parameters","MaximumTransferSize",0x10001,65536
;HKR,"Parameters","MaximumTransferSize",0x10001,4096
;HKR,"Parameters","DebugLevel",0x10001,5
;HKR,"Parameters","DebugFlag",0x10001,0x000000FF
HKR,,NTMPDriver,,VwU3VFilter.sys

[VWUSBCam.Files.Ext]
VwU3VFilter.sys

[SourceDisksNames]
1=%Disk_Description%,,,

[SourceDisksFiles]
VwU3VFilter.sys=1
WdfCoInstaller01011.dll=1 ; make sure the number matches with SourceDisksNames

[DestinationDirs]
DefaultDestDir=12
CoInstaller_CopyFiles=11

[VWUSBCam.AddReg.Guid]
HKR,,DriverGUID,,%VWU3V.GUID%

;-------------- WDF Coinstaller installation
[VWUSBCam.Dev.NT.CoInstallers]
AddReg=CoInstaller_AddReg
CopyFiles=CoInstaller_CopyFiles

[CoInstaller_CopyFiles]
WdfCoInstaller01011.dll

[CoInstaller_AddReg]
HKR,,CoInstallers32,0x00010000, "WdfCoInstaller01011.dll,WdfCoInstaller"

[VWUSBCam.Dev.NT.Wdf]
KmdfService=VWUSBCam, VWUSBCam_wdfsect

[VWUSBCam.Dev.NTamd64.Wdf]
KmdfService=VWUSBCam, VWUSBCam_wdfsect

[VWUSBCam_wdfsect]
KmdfLibraryVersion=1.11

;---------------------------------------------------------------;

