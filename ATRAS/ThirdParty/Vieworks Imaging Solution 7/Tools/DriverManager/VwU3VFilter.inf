[Version]
Signature="$WINDOWS NT$"
Class=VWDevices
;ClassGUID={feefd076-591e-41cc-8382-c3f148989a80}
ClassGUID={1354185D-3C13-4b72-BFF9-9EA802513D34}
Provider=%VW%
DriverVer=01/05/2021,13.59.8.962
CatalogFile=VwU3VFilter.cat


; ================= Class section =====================

[ClassInstall32]
Addreg=VWUSBCamClassReg     

[VWUSBCamClassReg]
HKR,,,0,%VWCAMClassName%
HKR,,Icon,,-20

; ================= Device section =====================

[Manufacturer]
%MfgName%=VW,NTx86,NTamd64

; For XP and later
[VW.NTx86]
;VS-2MC
%USB\VID_2F0D&PID_FFFF.DeviceDesc%=VWUSBCam.Dev, USB\VID_2F0D&PID_FFFF&MI_00
;future products
%USB\VID_2F0D&PID_FFF0.DeviceDesc%=VWUSBCam.Dev, USB\VID_2F0D&PID_FFF0&MI_00
%USB\VID_2F0D&PID_FFF1.DeviceDesc%=VWUSBCam.Dev, USB\VID_2F0D&PID_FFF1&MI_00
%USB\VID_2F0D&PID_FFF2.DeviceDesc%=VWUSBCam.Dev, USB\VID_2F0D&PID_FFF2&MI_00
%USB\VID_2F0D&PID_FFF3.DeviceDesc%=VWUSBCam.Dev, USB\VID_2F0D&PID_FFF3&MI_00
%USB\VID_2F0D&PID_FFF4.DeviceDesc%=VWUSBCam.Dev, USB\VID_2F0D&PID_FFF4&MI_00
