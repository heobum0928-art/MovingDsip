<UserControl x:Class="Project.DeepLearning.UI.ClassListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Project.DeepLearning.UI"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded"
             
             Background="White"
             
             d:DesignHeight="800" d:DesignWidth="1900"
             
             >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="Add Class" 
                    FontSize="25" 
                    FontWeight="Bold" 
                    Width="200" 
                    Margin="10, 5"
                    Command="{Binding AddClassCommand}"
                    />


            <Separator Width="50"/>

            <Label Content="Width : " Margin="10, 5" Width="100" FontWeight="Bold" FontSize="25" VerticalContentAlignment="Center"/>

            <TextBox Width="100" Margin="10, 5" FontWeight="Bold" FontSize="25" VerticalContentAlignment="Center"
                     Text="{Binding ItemWidth}"/>
            <Label Content="px" Margin="10, 5" FontWeight="Bold" FontSize="25" VerticalContentAlignment="Center"/>


            <Separator Width="15"/>


            <Label Content="Height : " Margin="10, 5" Width="100" FontWeight="Bold" FontSize="25" VerticalContentAlignment="Center"/>

            <TextBox Width="100" Margin="10, 5" FontWeight="Bold" FontSize="25" VerticalContentAlignment="Center"
                     Text="{Binding ItemHeight}"/>
            <Label Content="px" Margin="10, 5" FontWeight="Bold" FontSize="25" VerticalContentAlignment="Center"/>

            <Separator Width="30"/>

            <Button Content="Items Save" 
                    FontSize="25" 
                    FontWeight="Bold" 
                    Width="200" 
                    Margin="10, 5"
                    Command="{Binding ItemsSaveCommand}"
                    />

            <Separator Width="200" Background="White"/>
            <TextBox Width="200" Margin="10, 5" FontWeight="Bold" FontSize="20" VerticalContentAlignment="Center"
                     Text="{Binding ModelName}" IsReadOnly="True"/>


            <Button Content="Model Load" 
                    FontSize="25" 
                    FontWeight="Bold" 
                    Width="200" 
                    Margin="10, 5"
                    Command="{Binding ModelLoadCommand}"
                    />


            <Separator Width="100" Background="White"/>

            <Button Content="Extend" 
                    Name="extend_btn"
                    FontSize="25" 
                    FontWeight="Bold" 
                    Width="200" 
                    Margin="10, 5"
                    Click="Button_Extend_Click"
                    />
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="400" Name="extend_panel"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.Column="0"
                HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                Background="LightGray">
                <StackPanel Name="class_pn" Orientation="Horizontal"/>
            </ScrollViewer>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="7*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="50"/>                        
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Columns="2" 
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 >
                        <RadioButton GroupName="use_gpu"
                            Margin="20, 4" FontWeight="Bold" FontSize="10"
                            Content="CPU" Click="RadioButton_CPU_Click"/>

                        <RadioButton GroupName="use_gpu" 
                            Margin="20, 4" FontWeight="Bold" FontSize="10"
                            Content="GPU" Click="RadioButton_GPU_Click" IsChecked="True"/>
                    </UniformGrid>


                    <UniformGrid Grid.Row="1" Columns="2">
                        <Button 
                            Command="{Binding ModelTrainningCommand}"
                            Grid.Row="0" Margin="10, 4"
                            FontWeight="Bold" FontSize="15"
                            Content="New Trainning"/>

                        <Button 
                            Command="{Binding NextTrainningCommand}"
                            Grid.Row="0" Margin="10, 4"
                            FontWeight="Bold" FontSize="15"
                            Content="Next Trainning"/>
                    </UniformGrid>


                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Label Content="Epoch : " Width="100"/>
                        <TextBox Width="100" Margin="4, 2" Text="{Binding Epoch}" />

                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Label Content="Batch Size : " Width="100"/>
                        <TextBox Width="100" Margin="4, 2" Text="{Binding BatchSize}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <Label Content="Patience : " Width="100"/>
                        <TextBox Width="100" Margin="4, 2" Text="{Binding Patience}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" VerticalAlignment="Center">
                        <Label Content="Train Ratio(%) : " Width="100"/>
                        <TextBox Width="100" Margin="4, 2" Text="{Binding LearningRatio, StringFormat='{}{0:F5}'}"/>
                    </StackPanel>


                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    
                    <UniformGrid Columns="2" Grid.Row="0">
                        <Button 
                            Command="{Binding ModelSaveCommand}"
                            Grid.Row="0" Margin="10, 4, 5, 4"
                            FontWeight="Bold" FontSize="15"
                            Content="Model Save"/>

                        <Button 
                            Command="{Binding ModelSaveAsCommand}"
                            Grid.Row="0" Margin="5, 4, 10, 4"
                            FontWeight="Bold" FontSize="15"
                            Content="Model SaveAs..."/>

                    </UniformGrid>
                    
                    <TabControl Grid.Row="1" SelectedIndex="0">
                        <TabItem Header="Single">
                            <TabItem.Content>
                                <local:SingleSampleView/>
                            </TabItem.Content>
                        </TabItem>

                        <TabItem Header="Multi">
                            <TabItem.Content>
                                <local:MultiSampleView/>
                            </TabItem.Content>
                        </TabItem>
                    </TabControl>

                    <!--<UniformGrid Columns="2">
                        <Button 
                            Command="{Binding ModelSaveCommand}"
                            Grid.Row="0" Margin="10, 4, 5, 4"
                            FontWeight="Bold" FontSize="15"
                            Content="Model Save"/>

                        <Button 
                            Command="{Binding ModelSaveAsCommand}"
                            Grid.Row="0" Margin="5, 4, 10, 4"
                            FontWeight="Bold" FontSize="15"
                            Content="Model SaveAs..."/>

                    </UniformGrid>


                    <UniformGrid Grid.Row="1" Columns="2">
                         <Button 
                            Command="{Binding SampleLoadCommand}"
                            Grid.Row="1" Margin="10, 4"
                            FontWeight="Bold" FontSize="15"
                            Content="Single Load"/>


                        <Button 
                            Command="{Binding MultiSampleLoadCommand}"
                            Grid.Row="1" Margin="10, 4"
                            FontWeight="Bold" FontSize="15"
                            Content="Multi Load"/>
                    </UniformGrid>


                    <GroupBox Grid.Row="2">
                        <Image x:Name="MyImage" Stretch="Uniform" />
                    </GroupBox>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Label Content="Class : " Width="170" HorizontalContentAlignment="Right" FontSize="20" FontWeight="Bold"/>
                            <Label Width="100" Margin="4, 2" FontSize="20" FontWeight="Bold" Content="{Binding ClassName}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Label Content="Confidence(%) : " Width="170" HorizontalContentAlignment="Right" FontSize="20" FontWeight="Bold"/>
                            <Label Width="100" Margin="4, 2" FontSize="20" FontWeight="Bold" Content="{Binding PredictConfidence}"/>
                        </StackPanel>
                    </Grid>-->

                </Grid>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <GroupBox Grid.Row="0" Header="Confidence">
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Vertical" Name="ClassConfidenceBarList"/>
                    </ScrollViewer>                    
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Accuracy">
                    <lvc:CartesianChart Name="accuracyChart"
                            LegendLocation="Right"
                            Margin="10">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Epochs"
                          Labels="{Binding EpochLabels}"/>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Accuracy" LabelFormatter="{Binding YFormatter}" MinValue="0" MaxValue="1"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Loss">
                    <lvc:CartesianChart Name="lossChart"
                            LegendLocation="Right"
                            Margin="10">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Epochs"
                          Labels="{Binding EpochLabels}"/>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="loss" LabelFormatter="{Binding YLossFormatter}" MinValue="0" MaxValue="1"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </GroupBox>


            </Grid>
        </Grid>
    </Grid>
</UserControl>
