<UserControl x:Class="Project.UI.Common.ImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Project.UI.Common"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             DataContext="{Binding}" Name="uc">

    <Border Background="Black" BorderBrush="White" BorderThickness="1">
        <local:MyScrollViewer x:Name="sc"                     
                Background="Transparent"
                      MouseLeftButtonDown="sc_MouseLeftButtonDown"
                      PreviewMouseLeftButtonDown="sc_PreviewMouseLeftButtonDown"
                      PreviewMouseLeftButtonUp="sc_PreviewMouseLeftButtonUp"
                      PreviewMouseMove="sc_PreviewMouseMove"
                      PreviewMouseWheel="sc_PreviewMouseWheel"
                      >

            <Canvas Name="canv" Background="Black" Margin="0">
                <Image Name="img"
                       Canvas.Left="0"
                       Canvas.Top="0"
                       Cursor="Cross"
                       Margin="0"
                       SizeChanged="img_SizeChanged"
                       
                       PreviewMouseMove="img_PreviewMouseMove"
                       
                       PreviewMouseWheel="img_PreviewMouseWheel"
                          
                       ></Image>
                <Line
                    
                    x:Name="vLine"
                    Stroke="Orange"
                    StrokeThickness="2"
                    StrokeDashArray="1 2 4"/>
                <Line
                    
                    x:Name="hLine"
                    Stroke="Orange"
                    StrokeThickness="2" 
                    StrokeDashArray="1 2 4"/>
            </Canvas>
        </local:MyScrollViewer>
    </Border>
    
</UserControl>
