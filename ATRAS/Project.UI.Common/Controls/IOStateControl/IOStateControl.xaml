<UserControl x:Class="Project.UI.Common.IOStateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Project.UI.Common"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="300">
    <UserControl.Resources>
        <Style x:Key="userCtrlBase" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Margin" Value="0, 6, 0, 0"/>
        </Style>

        <Style x:Key="CenterGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="header_style" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment"
                                        Value="Center" />

            <Setter Property="Background" Value="LightGray"/>

            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="BorderBrush" Value="DimGray"/>

            <Setter Property="Height" Value="30"/>

            <Setter Property="Padding" Value="4"/>

        </Style>


        <local:IOStateColor x:Key="IOStateColorConv"/>
    </UserControl.Resources>
    <Grid>
        <GroupBox 
            Header="{Binding Header, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:IOStateControl}}}"
            >
             <DataGrid     
                    Style="{StaticResource userCtrlBase}"
                    ItemsSource="{Binding IOStateList, 
                        RelativeSource={RelativeSource Mode=FindAncestor,
                        AncestorType={x:Type local:IOStateControl}}}"
                 
                    Name="dgItems"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center"
                    FontWeight="Bold" IsReadOnly="True"
                    CanUserSortColumns="True"
                 
                    SelectedItem="{Binding SelectedIOState, 
                        RelativeSource={RelativeSource Mode=FindAncestor,
                        AncestorType={x:Type local:IOStateControl}}}"
                >
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="No." CanUserSort="False"
                                            HeaderStyle="{StaticResource header_style}"
                                            >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox 
                                    Tag="Number"
                                    BorderBrush="Transparent" 
                                         Text="{Binding Number, Mode=OneWay}"
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         IsReadOnly="True"
                                         />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>


                    <DataGridTemplateColumn Header="Description" CanUserSort="False"
                                            HeaderStyle="{StaticResource header_style}"
                                            MinWidth="100"
                                            Width="450"
                                            >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox 
                                    Tag="Description"
                                    BorderBrush="Transparent" 
                                         Text="{Binding Description}"
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         Height="20" IsReadOnly="True"
                                         />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>


                    <DataGridTemplateColumn Header="State" CanUserSort="False"
                                            HeaderStyle="{StaticResource header_style}"
                                            >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox 
                                    Tag="State"
                                    BorderBrush="Transparent" 
                                         Text="{Binding State}"
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         IsReadOnly="True"
                                         
                                         Background="{Binding State, Converter={StaticResource IOStateColorConv}}"
                                    PreviewMouseLeftButtonUp="TextBox_PreviewMouseLeftButtonUp"
                                    
                                         />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    
                    
                    
                    
                    
                </DataGrid.Columns>
            </DataGrid>           
        </GroupBox>
    </Grid>
</UserControl>
