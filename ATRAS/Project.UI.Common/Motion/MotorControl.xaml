<UserControl x:Class="Project.UI.Common.MotorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Project.UI.Common"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="400">
    <UserControl.Resources>
        <Style x:Key="baseCtl" TargetType="Control">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2, 0"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Label Style="{StaticResource baseCtl}" Grid.Column="0" Content="Axis Name" />
        <CheckBox Style="{StaticResource baseCtl}" Grid.Column="1"/>

        <Label Style="{StaticResource baseCtl}" Grid.Column="2"
               Content="current location"
             Name="currentLocation" Background="Pink" />
        
        <TextBox Style="{StaticResource baseCtl}" Text="Test" Grid.Column="3" Name="setLocation"/>
        <Label Style="{StaticResource baseCtl}" Grid.Column="4" Content="Vel :" />
        <TextBox Style="{StaticResource baseCtl}" Grid.Column="5"/>
        <Label Style="{StaticResource baseCtl}" Grid.Column="6" Content="Acc :" />
        <TextBox Style="{StaticResource baseCtl}" Grid.Column="7"/>
        <Button Grid.Column="8"/>
        <Button Grid.Column="9"/>
    </Grid>
        

</UserControl>
