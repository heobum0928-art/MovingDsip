<Window x:Class="Project.UI.Common.FolderRecipeWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Project.UI.Common"
             mc:Ignorable="d" 
        ResizeMode="NoResize"
            WindowStyle="None" WindowStartupLocation="CenterScreen"
            Title="Enter the name of new recipe to copy."
             Height="250" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" FontSize="20" FontWeight="Bold"
               Content="Enter the name of new recipe to copy." 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center"/>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Create Folder : " FontSize="20"/>

            <Separator Width="10" Background="White"/>

            <TextBox IsReadOnly="True" Width="430" Text="{Binding CreateFolderPath, Mode=OneWay}" FontSize="25"/>
        </StackPanel>

        <TextBox Grid.Row="2" Width="590" Height="50" FontSize="25" Text="{Binding FolderName}"/>


        <UniformGrid Grid.Row="3" Columns="2">
            <Button Content="OK" Margin="20, 10, 10, 10" Click="Button_OK_Click"></Button>
            <Button Content="Cancel" Margin="10, 10, 20, 10" Click="Button_CANCEL_Click"></Button>
        </UniformGrid>
        

    </Grid>
</Window>
