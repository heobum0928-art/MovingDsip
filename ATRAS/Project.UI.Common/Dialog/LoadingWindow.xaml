<Window x:Class="Project.UI.Common.LoadingWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Project.UI.Common"
             mc:Ignorable="d" 
             ResizeMode="NoResize"     
             WindowStyle="None" WindowStartupLocation="CenterScreen"
            Closed="Window_Closed"
            Closing="Window_Closing"
            Topmost="True"
            
             Height="250" Width="400">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" BorderBrush="Gray" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Training..." FontSize="30" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <ProgressBar Width="200" Height="20" IsIndeterminate="True"/>
            </StackPanel>
        </Border>


    </Grid>

    
</Window>
