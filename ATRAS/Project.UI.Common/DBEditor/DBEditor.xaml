<UserControl x:Class="Project.UI.Common.DBEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:local="clr-namespace:Project.UI.Common"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Project.UI.Common;component/Resources/Images.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="7*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Content="Category"
                   FontFamily="휴먼고딕" 
                   Background="DimGray"
                   Foreground="White" 
                   VerticalAlignment="Center"/>
            <ComboBox Name="Category"
                    Grid.Row="1"
                    FontFamily="휴먼고딕"
                    FontSize="40"
                    ItemsSource="{Binding Categories}"
                    SelectedItem ="{Binding SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                      />

            <DockPanel Grid.Row="5" Grid.RowSpan="4">
                <ListBox DockPanel.Dock="Top" BorderBrush="Black" BorderThickness="1" 
                         ItemsSource="{Binding DBList}"
                         SelectedItem ="{Binding SelectedDB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         SelectionChanged="ConfigurationOnSelectionChanged"
                         />                
            </DockPanel>

        </Grid>
        <DockPanel Grid.Column="1">
            <ToolBar  Background="#E5DEE9F1" DockPanel.Dock="Top" Height="40">
                <ToolBar.Resources>
                    <Style TargetType="{x:Type Image}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ButtonBase}, AncestorLevel=1}, Path=IsEnabled}" Value="False">
                                <Setter Property="Opacity" Value="0.30" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ToolBar.Resources>

                <Button Click="SaveBtnOnClick" Command="{Binding ImportCommand}"  ToolTip="Save New Version to DB" Margin="0,0,10,0">
                    <Image Source="{StaticResource Save}" Height="24"/>
                </Button>
                <Separator Margin="0,0,10,0" />

                <Separator Margin="0,0,10,0" />
                <Button Command="Undo" Margin="0,0,10,0">
                    <Image Source="{StaticResource Undo}" Height="24"/>
                </Button>
                <Button Command="Redo" Margin="0,0,10,0">
                    <Image Source="{StaticResource Redo}" Height="24"/>
                </Button>
                <Button Command="Find" Margin="0,0,10,0">
                    <Image Source="{StaticResource Find}" Height="24"/>
                </Button>

                <Separator Margin="0,0,10,0" />
            </ToolBar>
            <avalonEdit:TextEditor DockPanel.Dock="Top" 
                                   Name="textEditor"
                                   FontFamily="Consolas"
                                   Document="{Binding Document}"
                                   ShowLineNumbers="True"
                                   SyntaxHighlighting="XML"
                                   FontSize="16" TextChanged="textEditor_TextChanged"
                                   BorderBrush="Black"
                                   BorderThickness="1"
                                   />

        </DockPanel>        
        
    </Grid>

</UserControl>
