<UserControl x:Class="Project.UI.Common.NotifyLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Project.UI.Common"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             >
    <UserControl.Resources>
        <local:NotifyLogConverter x:Key="conv"/>
        <DataTemplate x:Key="notifyLogItems" DataType="LogItems">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Name="img" Stretch="Fill" Source="info.ico"/>
                <TextBlock Name="txtBlock" Grid.Column="1" VerticalAlignment="Center"                           
                       Text="{Binding Path=LogString}"
                           Foreground="White"
                           FontSize="10"
                           />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Path=LogLevel}" Value="{x:Static local:LogLevel.Error}">
                    <Setter TargetName="img" Property="Image.Source" Value="error.ico"/>
                    <Setter TargetName="txtBlock" Property="TextBlock.Background" Value="Red"/>
                    <Setter TargetName="txtBlock" Property="TextBlock.Foreground" Value="Yellow"/>
                    <Setter TargetName="txtBlock" Property="TextBlock.FontWeight" Value="Bold"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Path=LogLevel}" Value="{x:Static local:LogLevel.Warn}">
                    <Setter TargetName="img" Property="Image.Source" Value="error.ico"/>
                    <Setter TargetName="txtBlock" Property="TextBlock.Foreground" Value="Orange"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>
    <ListBox Name="notifyLogView" ItemTemplate="{StaticResource notifyLogItems}"
             ItemsSource="{x:Static local:NotifyLogger.LogItems}"  
             Background="DimGray" />
</UserControl>
